+    arcStage: "Rising Action", arcPct: 68, tone: "Deep / Gravelly",
+    scenes: ["SC-01: The Drop","SC-02: Alleyway Chase","SC-03: Safehouse","SC-04: Betrayal"]
+  },
+  elara: {
+    name: "Elara", role: "Supporting", roleLabel: "Overwatch / Splicer",
+    appearance: "Compact frame. Neural-port implants at her temples. Sharp eyes behind holographic lenses. Often remote — her physical presence is rare; her voice is constant.",
+    traits: ["Loyal","Brilliant","Concerned","Conflicted","Precise"],
+    arcStage: "Establishment", arcPct: 42, tone: "Clear / Measured",
+    scenes: ["SC-01: The Drop","SC-03: Safehouse","SC-05: Signal Loss"]
+  },
+  viktor: {
+    name: "Viktor", role: "Antagonist", roleLabel: "The Director / Architect",
+    appearance: "Impeccably dressed. Silver hair swept back. Cold grey eyes. Moves like someone who has never needed to hurry. The kind of stillness that reads as threat.",
