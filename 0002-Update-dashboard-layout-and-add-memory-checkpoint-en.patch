+let currentFilter = 'all';
+
+function selectChar(id) {
+  document.querySelectorAll('.char-card').forEach(c => c.classList.remove('selected'));
+  const card = document.querySelector(`.char-card[data-id="${id}"]`);
+  if (card) card.classList.add('selected');
+  const d = charData[id];
+  document.getElementById('dna-empty').classList.add('hidden');
+  document.getElementById('dna-content').classList.remove('hidden');
+  document.getElementById('dna-name').textContent = d.name;
+  document.getElementById('dna-role-label').textContent = d.roleLabel;
+  document.getElementById('dna-appearance').textContent = d.appearance;
+  document.getElementById('dna-tone').textContent = d.tone;
+  document.getElementById('dna-arc-stage').textContent = d.arcStage;
+  document.getElementById('dna-arc-pct').textContent = d.arcPct + '%';
+  document.getElementById('dna-arc-bar').style.width = d.arcPct + '%';
+  const traits = document.getElementById('dna-traits');
+  traits.innerHTML = d.traits.map(t => `<span class="px-2.5 py-1 rounded-full bg-primary/10 border border-primary/20 font-label-sm text-[10px] text-primary">${t}</span>`).join('');
+  const scenes = document.getElementById('dna-scenes');
+  scenes.innerHTML = d.scenes.map(s => `<div class="flex items-center gap-2 p-2 rounded-md bg-surface/30 border border-white/5 hover:border-white/10 transition-colors"><span class="material-symbols-outlined text-[13px] text-on-surface-variant">movie</span><span class="font-label-sm text-[10px] text-on-surface-variant">${s}</span></div>`).join('');
+}
