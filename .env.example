# Morphic Studio environment template
# Copy to .env for local development. Never commit real secrets.

PORT=5000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Required for database-backed API endpoints.
DATABASE_URL=postgres://user:password@localhost:5432/morphic_studio

# Optional AI provider selection: openai, openrouter, or gemini.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
APP_URL=http://localhost:5000

# Optional hardening. Leave unset/false for local prototype usage.
CORS_ORIGIN=
REQUIRE_API_KEY=false
API_KEY=

# Feature flags. Enable only when the corresponding subsystem is ready.
FEATURE_NEXT_FRONTEND=false
FEATURE_REDIS_QUEUE=false
FEATURE_LOCAL_STORAGE=true
FEATURE_IMAGE_GENERATION=false
FEATURE_MOTION_COMIC=false
FEATURE_ANIMATION_STUDIO=false

# Queue configuration. The current implementation uses an in-memory queue health shim;
# set QUEUE_PROVIDER=redis and REDIS_URL when BullMQ/Redis workers are added.
QUEUE_PROVIDER=memory
QUEUE_NAMES=image-gen,tts,export
REDIS_URL=

# Storage configuration for local development uploads.
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=./storage
STORAGE_PUBLIC_BASE_URL=
STORAGE_MAX_UPLOAD_MB=25
STORAGE_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,image/gif,audio/mpeg,audio/wav,audio/ogg,video/mp4,video/webm,application/pdf

# Image generation provider keys for the gateway expansion roadmap.
REPLICATE_API_TOKEN=
FAL_KEY=
